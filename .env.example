# ──────────────────────────────────────────────────────────────────────────────
# Configuração do Servidor MCP
# ──────────────────────────────────────────────────────────────────────────────

# Host para o servidor HTTP MCP
# Use 127.0.0.1 para desenvolvimento local (recomendado por segurança)
# Use 0.0.0.0 para expor em produção (ex.: dentro de container Docker)
MCP_HOST=127.0.0.1

# Porta para o servidor HTTP MCP
MCP_PORT=8000
